# Copy this file to .env and fill in values.

# OpenAI API key used for LLM-based entity extraction.
# Leave blank to run in spaCy-only (offline) mode.
OPENAI_API_KEY=

# Model used for extraction (must support JSON output / function calling).
OPENAI_MODEL=gpt-4o-mini

# Default OCR language(s) for Tesseract, e.g. "eng" or "eng+fra".
OCR_LANG=eng

# Minimum confidence (0-1) below which fields are flagged for review.
REVIEW_THRESHOLD=0.6

# Max upload size in megabytes.
MAX_UPLOAD_MB=25
